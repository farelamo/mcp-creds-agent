{{- with secret "mcp/data/ssh" -}}
SSH_USERNAME={{ .Data.data.username }}
SSH_PORT={{ .Data.data.port }}
SSH_HOST={{ .Data.data.host }}
SSH_PRIVATE_KEY=/run/secrets/ssh/id_ed25519
{{- range $key, $value := .Data.data.hosts | parseJSON }}
SSH_HOST_{{ $key | toUpper }}={{ $value }}
{{- end }}
{{- end }}
